# ============================================================
# Noor Framework - Development Dockerfile
# Dockerfile لبيئة التطوير مع hot reload
# ============================================================

FROM rust:1.96-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    curl \
    xz-utils \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install Zig for performance modules (optional - falls back to pure Rust)
RUN curl -L https://ziglang.org/download/0.11.0/zig-linux-x86_64-0.11.0.tar.xz -o /tmp/zig.tar.xz && \
    tar -xJf /tmp/zig.tar.xz -C /usr/local && \
    ln -s /usr/local/zig-linux-x86_64-0.11.0/zig /usr/local/bin/zig && \
    rm /tmp/zig.tar.xz || echo "Zig installation skipped - using pure Rust fallback"

# Install cargo-watch for hot reload
RUN cargo install cargo-watch

# Install cargo-expand for debugging macros
RUN cargo install cargo-expand

WORKDIR /app

# Copy Cargo files first for better caching
COPY Cargo.toml Cargo.lock* build.rs ./

# Create a dummy source to build dependencies
RUN mkdir -p src/bin && \
    echo 'fn main() {}' > src/bin/noor.rs && \
    echo 'fn main() {}' > src/bin/server.rs && \
    echo 'pub fn init() {}' > src/lib.rs && \
    cargo build --release 2>/dev/null || true

# Remove dummy source
RUN rm -rf src

# Copy actual source code
COPY src/ ./src/
COPY noor.toml ./

# Create storage directories
RUN mkdir -p storage/cache storage/logs storage/uploads

# Expose port
EXPOSE 8080

# Default command (can be overridden)
CMD ["cargo", "watch", "-x", "run --bin noor-server"]
