<div class="container">
    <h1 style="color: #2c3e50; margin-bottom: 30px;">{{title}}</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
        {{#each stats}}
        <div class="card" style="text-align: center;">
            <h3 style="color: #7f8c8d; font-size: 14px; text-transform: uppercase;">{{this.label}}</h3>
            <div style="font-size: 32px; font-weight: 700; color: #2c3e50;">{{this.value}}</div>
        </div>
        {{/each}}
    </div>
    
    <div class="card">
        <div class="flex-between mb-2">
            <h2>{{table_title}}</h2>
            {{#if create_url}}
            <a href="{{create_url}}" class="btn btn-success btn-sm">+ إضافة جديد</a>
            {{/if}}
        </div>
        
        <table class="table">
            <thead>
                <tr>
                    {{#each columns}}
                    <th>{{this}}</th>
                    {{/each}}
                    <th>إجراءات</th>
                </tr>
            </thead>
            <tbody>
                {{#each rows}}
                <tr>
                    {{#each this.cells}}
                    <td>{{{this}}}</td>
                    {{/each}}
                    <td>
                        {{#if ../edit_url}}
                        <a href="{{../edit_url}}/{{this.id}}" class="btn btn-primary btn-sm">تعديل</a>
                        {{/if}}
                        {{#if ../delete_url}}
                        <a href="{{../delete_url}}/{{this.id}}" class="btn btn-danger btn-sm" data-confirm="هل أنت متأكد؟">حذف</a>
                        {{/if}}
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        
        {{#if pagination}}
        <div style="margin-top: 20px; text-align: center;">
            {{#if pagination.prev}}
            <a href="?page={{pagination.prev}}" class="btn btn-secondary btn-sm">السابق</a>
            {{/if}}
            <span style="margin: 0 15px;">صفحة {{pagination.current}} من {{pagination.last}}</span>
            {{#if pagination.next}}
            <a href="?page={{pagination.next}}" class="btn btn-secondary btn-sm">التالي</a>
            {{/if}}
        </div>
        {{/if}}
    </div>
</div>
