# Noor Framework Environment Variables
# متغيرات بيئة إطار عمل نور
# ============================================================
# Copy this file to .env and adjust values as needed
# انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة
# ============================================================

# Application | التطبيق
APP_ENV=development
APP_NAME=Noor App

# Server | الخادم
NOOR_SERVER_HOST=0.0.0.0
NOOR_SERVER_PORT=8080

# Database | قاعدة البيانات
DATABASE_URL=sqlite://storage/noor.db
# For PostgreSQL: postgres://user:pass@localhost:5432/noor
# For MySQL: mysql://user:pass@localhost:3306/noor

# Security | الأمان
JWT_SECRET=change-this-to-a-strong-random-secret-key-in-production
# Generate with: openssl rand -hex 32

# Logging | التسجيل
RUST_LOG=info
# Options: error, warn, info, debug, trace

# Docker Compose | Docker Compose
NOOR_PORT=8080
POSTGRES_PASSWORD=noor_secret
